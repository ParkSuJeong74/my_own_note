{
  "name": "@my-own-note/desktop",
  "version": "1.0.0",
  "description": "Desktop application for My Own Note",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "tsc -w",
    "build": "tsc && electron-builder --dir",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "test": "jest"
  },
  "keywords": [
    "electron",
    "desktop",
    "application"
  ],
  "author": "Ellie",
  "license": "ISC",
  "dependencies": {
    "@my-own-note/common": "workspace:*",
    "@my-own-note/ui": "workspace:*",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/jest": "^29.5.6",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "build": {
    "appId": "com.myownnote.desktop",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
