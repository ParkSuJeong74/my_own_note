      "targets": [{ "expr": "sum(pg_database_size_bytes{project=~\"$project\"})", "refId": "A" }],
      "title": "Database size",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
