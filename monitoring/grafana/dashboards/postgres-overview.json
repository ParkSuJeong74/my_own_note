      "targets": [{ "expr": "sum(pg_stat_database_numbackends{project=~\"$project\",datname!~\"template.*\"})", "refId": "A" }],
      "title": "Connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
