      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(count_over_time({project=\"alcove\"} |~ \"(?i)error\" [$__range]))", "queryType": "instant", "refId": "A" }],
      "title": "Errors in range",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "sum by (service_name) (count_over_time({project=\"alcove\"} [$__auto]))", "legendFormat": "{{service_name}}", "refId": "A" }],
      "title": "Log volume by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 4 },
      "id": 3,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
