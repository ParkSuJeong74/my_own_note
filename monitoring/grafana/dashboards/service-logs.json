      { "current": { "text": "All", "value": "$__all" }, "datasource": { "type": "loki", "uid": "loki" }, "definition": "label_values({project=~\"$project\"}, service_name)", "includeAll": true, "label": "Service", "name": "service", "query": "label_values({project=~\"$project\"}, service_name)", "refresh": 1, "type": "query" },
